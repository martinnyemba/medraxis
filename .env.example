# Medraxis environment configuration -- copy to .env and edit.
# NEVER commit a real .env. Secrets are read from the environment only.

# ---------------------------------------------------------------------------
# Core
# ---------------------------------------------------------------------------
DJANGO_SETTINGS_MODULE=config.settings.local
DJANGO_DEBUG=true
DJANGO_SECRET_KEY=change-me-to-a-long-random-string
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
DJANGO_TIME_ZONE=UTC

# ---------------------------------------------------------------------------
# Database
#   Local default is SQLite (no value needed).
#   Production example (PostgreSQL):
#   DATABASE_URL=postgres://medraxis:secret@localhost:5432/medraxis
# ---------------------------------------------------------------------------
# DATABASE_URL=postgres://medraxis:secret@localhost:5432/medraxis

# ---------------------------------------------------------------------------
# Cache / broker (optional locally; Celery runs eagerly without Redis)
# ---------------------------------------------------------------------------
# REDIS_URL=redis://localhost:6379/0
# CELERY_BROKER_URL=redis://localhost:6379/1
# CELERY_RESULT_BACKEND=redis://localhost:6379/2

# ---------------------------------------------------------------------------
# Authentication / JWT
# ---------------------------------------------------------------------------
JWT_ACCESS_MINUTES=60
JWT_REFRESH_DAYS=7

# ---------------------------------------------------------------------------
# Platform settings
# ---------------------------------------------------------------------------
PATIENT_IDENTIFIER_PREFIX=MRX
DEFAULT_CURRENCY=USD
FHIR_ENABLED=true

# ---------------------------------------------------------------------------
# Seeding (optional). If set, `python manage.py seed` creates a superuser.
# ---------------------------------------------------------------------------
# DJANGO_SEED_ADMIN_PASSWORD=

# ---------------------------------------------------------------------------
# Email (production)
# ---------------------------------------------------------------------------
# EMAIL_HOST=
# EMAIL_PORT=587
# EMAIL_HOST_USER=
# EMAIL_HOST_PASSWORD=

# ---------------------------------------------------------------------------
# Payment gateways (secrets are read from the environment ONLY)
# ---------------------------------------------------------------------------
# Stripe (cards/wallets)
# STRIPE_SECRET_KEY=sk_test_xxx
# STRIPE_PUBLISHABLE_KEY=pk_test_xxx
# STRIPE_WEBHOOK_SECRET=whsec_xxx
# Flutterwave (cards + African mobile money: M-Pesa, MoMo, ...)
# FLUTTERWAVE_SECRET_KEY=FLWSECK_TEST-xxx
# FLUTTERWAVE_PUBLIC_KEY=FLWPUBK_TEST-xxx
# FLUTTERWAVE_SECRET_HASH=your-webhook-verif-hash
# Lenco (African mobile money & bank collections)
# LENCO_API_KEY=xxx
# LENCO_WEBHOOK_SECRET=xxx
# Manual/test gateway shared secret (dev only)
# MANUAL_GATEWAY_WEBHOOK_SECRET=test-secret

# ---------------------------------------------------------------------------
# Production hardening / CORS
# ---------------------------------------------------------------------------
# DJANGO_SECURE_SSL_REDIRECT=true
# CORS_ALLOWED_ORIGINS=https://app.example.com
