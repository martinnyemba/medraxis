# Medraxis frontend environment.
# Copy to .env.local for local overrides (Vite only exposes VITE_*-prefixed vars).

# Base origin of the Django API. Leave blank in development to use the Vite
# dev-server proxy (see vite.config.ts), which forwards /api and /fhir to the
# backend same-origin. In production, point this at the deployed backend, e.g.
# VITE_API_BASE_URL=https://api.medraxis.example.com
VITE_API_BASE_URL=

# Backend target the dev-server proxy forwards to (defaults to localhost:8000).
# VITE_API_PROXY_TARGET=http://localhost:8000
